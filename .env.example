# .env.example
#
# This is a TEMPLATE for environment variables used by the AI Daily Digest project.
# It is safe to commit to Git — it contains no real secrets, only placeholder values.
#
# HOW TO USE:
#   1. Copy this file and name the copy `.env`:
#        cp .env.example .env
#   2. Fill in your real credentials in the `.env` file.
#   3. NEVER commit `.env` to Git — it's listed in .gitignore.
#
# The project will use the `python-dotenv` library (to be added later) to
# automatically load these variables so your code can access them via:
#   import os
#   value = os.getenv("VARIABLE_NAME")
#
# ---------------------------------------------------------------------------

# --- Gemini API (Google) ---
# Used to summarize news articles using Google's Gemini LLM.
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# --- NewsAPI ---
# Used by sources/newsapi_source.py to fetch AI news headlines from hundreds of publishers.
# Free tier: 100 requests/day, up to 100 articles per request.
# Register and get your key at: https://newsapi.org/register
NEWSAPI_KEY=your_newsapi_key_here

# --- Reddit API ---
# Used to fetch posts from AI-related subreddits (e.g., r/MachineLearning, r/artificial).
# Create an app at: https://www.reddit.com/prefs/apps
# Set type to "script" for personal use.
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here

# --- Gmail (for sending the digest email) ---
# The Gmail address you want to send the digest FROM.
# NOTE: Use an App Password, NOT your real Gmail password.
# Enable 2FA, then generate an App Password at:
#   https://myaccount.google.com/apppasswords
GMAIL_ADDRESS=your_gmail_address@gmail.com
GMAIL_APP_PASSWORD=your_16_character_app_password_here
