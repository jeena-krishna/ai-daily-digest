# .gitignore — tells Git which files to never track
#
# This is important because:
#   - `.env` contains real API keys and passwords — NEVER commit this
#   - `__pycache__` and `.pyc` files are auto-generated bytecode, not source code
#   - virtual environment folders can be recreated from requirements.txt

# --- Secret/environment files ---
# Your real credentials. .env.example (the template) IS committed — .env is NOT.
.env

# --- Python bytecode ---
# Python compiles .py files into bytecode for speed. These are auto-regenerated
# and don't belong in version control.
__pycache__/
*.py[cod]
*$py.class
*.pyc

# --- Virtual environment directories ---
# If you create a virtual environment (venv), its folder should not be committed.
# Recreate it with: python -m venv venv && pip install -r requirements.txt
venv/
.venv/
env/
.env/

# --- Distribution / packaging ---
dist/
build/
*.egg-info/

# --- macOS system files ---
.DS_Store

# --- IDE and editor files ---
.vscode/
.idea/
*.suo
*.sw?

# --- Vector database and outputs ---
digest_memory/
digest_preview.html

